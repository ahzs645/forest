{
  "name": "bc-forestry-trail",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tui": "bun --watch run cli-game.tsx",
    "build": "vite build",
    "preview": "vite preview",
    "serve:e2e": "npm run build && vite preview --host 127.0.0.1 --strictPort",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "playtest:matrix": "node scripts/playwright-matrix.mjs",
    "play": "bun run cli-game.tsx",
    "play:blessed": "node cli-game.js",
    "import:legacy": "node scripts/import-legacy-content.mjs",
    "refresh:planning-blocks": "node scripts/generate-planning-block-options.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.7.0",
    "sass": "^1.97.1",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
    "blessed": "^0.1.81",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
